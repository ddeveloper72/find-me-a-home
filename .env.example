# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost/findmehome

# Azure AD B2C Configuration
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_TENANT_NAME=your-tenant-name
AZURE_AD_AUTHORITY=https://your-tenant.b2clogin.com/your-tenant.onmicrosoft.com/B2C_1_signupsignin
AZURE_AD_REDIRECT_PATH=/auth/callback

# Azure Storage (for property images)
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER=property-images

# Email Configuration (for alerts)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password

# API Keys
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GEOADDRESS_CHECKED_API_TOKEN=your-geoaddress-checked-token

# Daft.ie API (requires personal developer key)
DAFT_API_KEY=your-daft-api-key-here

# Application URLs
BASE_URL=http://localhost:5000
